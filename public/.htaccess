# SPA fallback voor React Router — deep links en refresh op DirectAdmin
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bestaande bestanden en mappen normaal serveren (incl. contact.php, assets)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alle overige requests naar index.html
  RewriteRule . /index.html [L]
</IfModule>

# Compressie
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache voor statische assets (Vite hasht bestandsnamen, dus lange cache is veilig)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>

# Geen directory listing
Options -Indexes

# Beveilig configuratie- en verborgen bestanden
<FilesMatch "^(contact-config\.php|\.env|composer\.(json|lock))$">
  Require all denied
</FilesMatch>
